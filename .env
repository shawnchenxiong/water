# VoltWise 开发环境配置
# 注意：此文件会被提交到版本控制，请勿包含敏感信息
# 如需本地配置，请创建 .env.local 文件

# 应用标题
VITE_APP_TITLE=VoltWise 光伏智慧运维管理系统

# API 基础地址
VITE_API_BASE_URL=/api

# WebSocket 地址
VITE_WS_URL=ws://localhost:8080

# 使用 Mock 数据（开发环境默认使用 Mock）
VITE_MOCK=true

# 组态设计器服务地址（来自 source-code/.env.production）
VITE_APP_RCSCADA_API=https://zt.ccswkj.cn

