# VoltWise 生产环境配置

# 应用标题
VITE_APP_TITLE=VoltWise 光伏智慧运维管理系统

# API 基础地址
VITE_API_BASE_URL=https://service.ccswkj.cn/jeecg-boot

# 不使用 Mock 数据
VITE_MOCK=false

# 不开启 Sourcemap
VITE_SOURCEMAP=false

# 控制台日志级别
VITE_LOG_LEVEL=error

# 组态设计器服务地址（来自 source-code/.env.production）
VITE_APP_RCSCADA_API=https://zt.ccswkj.cn
