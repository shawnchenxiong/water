# VoltWise 生产环境配置

# 应用标题
VITE_APP_TITLE=VoltWise 智慧管理系统

# API 基础地址
VITE_API_BASE_URL=https://service.ccswkj.cn/jeecg-boot

# 代理配置 (如果是本地以生产模式预览可以使用)
VITE_PROXY_TARGET=https://service.ccswkj.cn
VITE_PROXY_WS_TARGET=wss://service.ccswkj.cn

# 不使用 Mock 数据
VITE_MOCK=false

# 不开启 Sourcemap
VITE_SOURCEMAP=false

# 控制台日志级别
VITE_LOG_LEVEL=error

# 组态设计器服务地址（本地部署的编辑器页面）
VITE_APP_RCSCADA_API=https://service.ccswkj.cn/rcscada

# 真实后端API (用于获取组态列表，以及透传给 iframe)
VITE_APP_API_URL=https://service.ccswkj.cn/jeecg-boot
VITE_APP_WS_API_URL=wss://service.ccswkj.cn/jeecg-boot
