# VoltWise 开发环境配置

# 应用标题
VITE_APP_TITLE=VoltWise 光伏智慧运维管理系统 [开发环境]

# API 基础地址
VITE_API_BASE_URL=https://service.ccswkj.cn/jeecg-boot

# 使用 Mock 数据
VITE_MOCK=true

# 是否开启 Sourcemap
VITE_SOURCEMAP=true

# 控制台日志级别 (debug | info | warn | error)
VITE_LOG_LEVEL=debug

# 组态设计器服务地址（来自 source-code/.env.production）
VITE_APP_RCSCADA_API=https://zt.ccswkj.cn
