# VoltWise 开发环境配置

# 应用标题
VITE_APP_TITLE=鹤问湖净水 [开发环境]

# API 基础地址 (使用相对路径以匹配代理)
VITE_API_BASE_URL=/jeecg-boot

# 代理配置 (用于 vite.config.ts 解决跨域)
VITE_PROXY_TARGET=https://service.ccswkj.cn
VITE_PROXY_WS_TARGET=wss://service.ccswkj.cn

# 使用 Mock 数据
VITE_MOCK=false

# 是否开启 Sourcemap
VITE_SOURCEMAP=true

# 控制台日志级别 (debug | info | warn | error)
VITE_LOG_LEVEL=debug

# 真实后端API (用于获取组态列表，以及透传给 iframe)
VITE_APP_API_URL=https://service.ccswkj.cn/jeecg-boot
VITE_APP_WS_API_URL=wss://service.ccswkj.cn/jeecg-boot
